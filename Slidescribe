step_download_video() {
  # Scarica il video YouTube in massima qualità e lo remuxa in MKV.
  if [ "$SKIP_DOWNLOAD" -eq 1 ]; then
    log "Download video skippato"
    return 0
  fi

  if [ "$FORCE_ALL" -eq 0 ] && file_exists_nonempty "$VIDEO_PATH"; then
    log "Video già presente, skip download: $VIDEO_PATH"
    return 0
  fi

  log "Download video in massima qualità + remux MKV..."
  run_ytdlp_with_policy "$YTDLP_VIDEO_STDERR" "download video" \
    -f "bv*+ba/b" \
    --remux-video mkv \
    -o "${WORKDIR}/${VIDEO_BASENAME}.%(ext)s" \
    -- "$YOUTUBE_URL"

  require_file "$VIDEO_PATH"
  log "Video pronto: $VIDEO_PATH"
}

step_download_subs() {
  # Scarica i sottotitoli automatici e li converte in SRT.
  if [ "$SKIP_SUBS" -eq 1 ]; then
    log "Download sottotitoli skippato"
    return 0
  fi

  if [ "$FORCE_ALL" -eq 0 ] && file_exists_nonempty "$ORIGINAL_SRT"; then
    log "SRT originale già presente, skip download: $ORIGINAL_SRT"
    return 0
  fi

  log "Download sottotitoli automatici + conversione SRT..."
  run_ytdlp_with_policy "$YTDLP_SUBS_STDERR" "download sottotitoli" \
    --skip-download \
    --write-auto-subs \
    --sub-langs "$SUB_LANGS" \
    --convert-subs srt \
    -o "${WORKDIR}/${VIDEO_BASENAME}.%(ext)s" \
    -- "$YOUTUBE_URL"

  # Cerca il primo file SRT generato compatibile col basename scelto.
  DOWNLOADED_SRT="$({
    find "$WORKDIR" -maxdepth 1 -type f \
      \( -name "${VIDEO_BASENAME}*.srt" \) \
      | sort | head -n 1
  })"

  [ -n "${DOWNLOADED_SRT:-}" ] || die "Nessun file SRT trovato dopo il download dei sottotitoli"
  cp -f "$DOWNLOADED_SRT" "$ORIGINAL_SRT"
  require_file "$ORIGINAL_SRT"
  log "SRT originale pronto: $ORIGINAL_SRT"
}

task_screenshots() {
  # Lancia Screenshot_grabber.py con le opzioni coerenti alla config attuale.
  local -a cmd

  if [ "$SKIP_SCREENSHOTS" -eq 1 ]; then
    log "Screenshot_grabber skippato"
    return 0
  fi

  if [ "$SCREENSHOTS_NEEDED" -eq 0 ]; then
    log "Screenshot_grabber non necessario"
    return 0
  fi

  cmd=(
    "$VENV_PYTHON"
    -u
    "${SCRIPT_DIR}/${SCREENSHOT_SCRIPT}"
    "$VIDEO_PATH"
    -o "$SLIDES_DIR"
  )

  if [ "$SKIP_FIRST_SEC" != "0" ]; then
    cmd+=(--skip-first-sec "$SKIP_FIRST_SEC")
  fi

  if [ "$SKIP_LAST_SEC" != "0" ]; then
    cmd+=(--skip-last-sec "$SKIP_LAST_SEC")
  fi

  if [ "$ROI_MODE" = "separate" ]; then
    cmd+=(--separate-trigger-roi)
  fi

  if [ "$ENHANCE_SLIDE" -eq 1 ]; then
    cmd+=(--enhance-slide)
  fi

  if [ -n "$ENHANCE_PRESET" ]; then
    cmd+=(--enhance-preset "$ENHANCE_PRESET")
  fi

  log "Avvio Screenshot_grabber..."
  log "Stdout: $SCREENSHOT_STDOUT"
  log "Stderr: $SCREENSHOT_STDERR"
  run_logged_command "$SCREENSHOT_STDOUT" "$SCREENSHOT_STDERR" 1 "${cmd[@]}"

  # Verifiche minime di corretto completamento.
  [ -d "$SLIDES_DIR" ] || die "Screenshot_grabber terminato ma cartella slide non trovata: $SLIDES_DIR"
  [ -f "${SLIDES_DIR}/slides.csv" ] || die "Screenshot_grabber terminato ma slides.csv non trovato in: $SLIDES_DIR"
  [ -s "${SLIDES_DIR}/slides.csv" ] || die "Screenshot_grabber terminato ma slides.csv è vuoto: ${SLIDES_DIR}/slides.csv"
}

prepare_lesson_context_from_srt() {
  # 1) Deduplica l'SRT originale in raw_text.txt
  # 2) Se LESSON_TOPIC e TERMINOLOGY_CONTEXT sono entrambi vuoti,
  #    prova a inferirli automaticamente via chatgpt
  # 3) In ogni caso rigenera PROMPT_TEXT finale
  local metadata_prompt=""
  local upload_json=""
  local file_id=""
  local inferred_lesson_topic=""
  local inferred_terminology_context=""
  local -a chatgpt_cmd

  require_file "$ORIGINAL_SRT"

  if [ "$FORCE_ALL" -eq 1 ] || [ ! -s "$RAW_TEXT_PATH" ]; then
    log "Avvio deduplicazione SRT -> raw_text.txt..."
    run_logged_command "$DEDUP_STDOUT" "$DEDUP_STDERR" 1 \
      "$VENV_PYTHON" "${SCRIPT_DIR}/${DEDUP_SCRIPT}" \
      --srt "$ORIGINAL_SRT" \
      --output "$RAW_TEXT_PATH"
  else
    log "raw_text.txt già presente, skip dedup: $RAW_TEXT_PATH"
  fi

  require_file "$RAW_TEXT_PATH"

  if [ -n "$LESSON_TOPIC" ] || [ -n "$TERMINOLOGY_CONTEXT" ]; then
    log "Metadati lezione già forniti manualmente in tutto o in parte: salto inferenza automatica"
    refresh_prompt_text
    return 0
  fi

  if [ "$FORCE_ALL" -eq 1 ] || [ ! -s "$LESSON_CONTEXT_OUTPUT" ]; then
    log "Upload raw_text.txt a ChatGPT per inferenza argomento/terminologia..."
    upload_json="$(run_chatgpt_upload "$RAW_TEXT_PATH" "$LESSON_CONTEXT_UPLOAD_STDERR")"
    file_id="$(extract_json_field_with_python "$upload_json" "id")"
    [ -n "$file_id" ] || {
      warn "Impossibile estrarre file_id per inferenza automatica del contesto. Uso prompt generico."
      refresh_prompt_text
      return 0
    }

    metadata_prompt="$(build_lesson_metadata_prompt)"

    chatgpt_cmd=(
      chatgpt
      --no-resume
      -o "$LESSON_CONTEXT_OUTPUT"
      --file-id "$file_id"
      -m "$MODEL"
      -t "$TEMPERATURE"
      --verbosity "$LLM_VERBOSITY"
    )

    if [ -n "$MAX_OUTPUT_TOKENS" ]; then
      chatgpt_cmd+=(-k "$MAX_OUTPUT_TOKENS")
    fi

    if [ -n "$EFFORT" ]; then
      chatgpt_cmd+=(--effort "$EFFORT")
    fi

    chatgpt_cmd+=(--save-raw "$LESSON_CONTEXT_RAW_JSON")
     
    chatgpt_cmd+=("$metadata_prompt")

    log "Invio prompt di inferenza metadata lezione..."

    run_chatgpt_cmd_with_retry "$LESSON_CONTEXT_RUN_STDERR" "${chatgpt_cmd[@]}"

  else
    log "Risposta metadata già presente, skip inferenza: $LESSON_CONTEXT_OUTPUT"
  fi

  if [ -s "$LESSON_CONTEXT_OUTPUT" ]; then
    inferred_lesson_topic="$(extract_lesson_metadata_field "$LESSON_CONTEXT_OUTPUT" lesson_topic 2>/dev/null || true)"
    inferred_terminology_context="$(extract_lesson_metadata_field "$LESSON_CONTEXT_OUTPUT" terminology_context 2>/dev/null || true)"

    if [ -n "$inferred_lesson_topic" ]; then
      LESSON_TOPIC="$inferred_lesson_topic"
      log "Argomento lezione inferito automaticamente."
    else
      warn "Parsing argomento lezione fallito: uso prompt generico."
    fi

    if [ -n "$inferred_terminology_context" ]; then
      TERMINOLOGY_CONTEXT="$inferred_terminology_context"
      log "Terminologia inferita automaticamente."
    else
      warn "Parsing terminologia fallito: procedo senza contesto terminologico automatico."
    fi
  else
    warn "Output metadata non disponibile o vuoto: uso prompt generico."
  fi

  refresh_prompt_text
}


run_llm_pipeline() {
  # Pipeline completa di correzione testi:
  # 0) dedup SRT e inferenza automatica contesto lezione
  # 1) export slide+testo in chunk
  # 2) upload chunk a ChatGPT
  # 3) salvataggio chunk corretti
  # 4) import/merge finale in JSON unico
  local slides_csv="${SLIDES_DIR}/slides.csv"
  local expected_slides
  local chunk_file
  local chunk_basename
  local corrected_file
  local upload_json
  local file_id
  local raw_json_path
  local -a chatgpt_cmd

  if [ "$SKIP_LLM" -eq 1 ]; then
    log "Pipeline LLM skippata"
    return 0
  fi

  if [ "$LLM_PIPELINE_NEEDED" -eq 0 ]; then
    log "Pipeline LLM non necessaria"
    return 0
  fi

  require_file "$slides_csv"
  require_file "$ORIGINAL_SRT"
  require_openai_api_key

  prepare_lesson_context_from_srt
  [ -n "$PROMPT_TEXT" ] || die "PROMPT_TEXT vuoto dopo la preparazione del contesto lezione"

  log "Avvio export_for_llm.py..."
  if [ "$VERBOSE_LOGS" -eq 1 ]; then
    run_logged_command "$EXPORT_STDOUT" "$EXPORT_STDERR" 1 \
      "$VENV_PYTHON" "${SCRIPT_DIR}/${EXPORT_SCRIPT}" \
      --srt "$ORIGINAL_SRT" \
      --slides-csv "$slides_csv" \
      --output-dir "$LLM_CHUNKS_DIR" \
      --base-name "$VIDEO_BASENAME" \
      --chunk-size "$CHUNK_SIZE" \
      --skip-first-sec "$SKIP_FIRST_SEC" \
      --skip-last-sec "$SKIP_LAST_SEC"
  else
    "$VENV_PYTHON" "${SCRIPT_DIR}/${EXPORT_SCRIPT}" \
      --srt "$ORIGINAL_SRT" \
      --slides-csv "$slides_csv" \
      --output-dir "$LLM_CHUNKS_DIR" \
      --base-name "$VIDEO_BASENAME" \
      --chunk-size "$CHUNK_SIZE" \
      --skip-first-sec "$SKIP_FIRST_SEC" \
      --skip-last-sec "$SKIP_LAST_SEC" \
      >"$EXPORT_STDOUT" 2>"$EXPORT_STDERR"
  fi

  expected_slides="$(count_slides_from_csv "$slides_csv")"
  [ -n "$expected_slides" ] || die "Impossibile contare le slide da $slides_csv"
  log "Slide attese dal CSV: $expected_slides"

  shopt -s nullglob
  local chunk_files=( "$LLM_CHUNKS_DIR"/"${VIDEO_BASENAME}".chunk_*.txt )
  shopt -u nullglob
  [ "${#chunk_files[@]}" -gt 0 ] || die "Nessun chunk generato in $LLM_CHUNKS_DIR"

  for chunk_file in "${chunk_files[@]}"; do
    chunk_basename="$(basename "$chunk_file" .txt)"
    corrected_file="${LLM_CORRECTED_DIR}/${chunk_basename}.corrected.txt"
    raw_json_path="${LLM_CORRECTED_DIR}/${chunk_basename}.raw.json"

    if [ "$FORCE_ALL" -eq 0 ] && file_exists_nonempty "$corrected_file"; then
      log "Chunk corretto già presente, skip: $corrected_file"
      continue
    fi

    log "Upload chunk a ChatGPT: $chunk_file"
    upload_json="$(run_chatgpt_upload "$chunk_file" "$CHATGPT_UPLOAD_STDERR")"
    file_id="$(extract_json_field_with_python "$upload_json" "id")"
    [ -n "$file_id" ] || die "Impossibile estrarre file_id per chunk: $chunk_file"

    log "Invio prompt a ChatGPT per chunk: $chunk_basename"
    chatgpt_cmd=(
      chatgpt
      --no-resume
      -o "$corrected_file"
      --file-id "$file_id"
      -m "$MODEL"
      -t "$TEMPERATURE"
      --verbosity "$LLM_VERBOSITY"
    )

    if [ -n "$MAX_OUTPUT_TOKENS" ]; then
      chatgpt_cmd+=(-k "$MAX_OUTPUT_TOKENS")
    fi

    if [ -n "$EFFORT" ]; then
      chatgpt_cmd+=(--effort "$EFFORT")
    fi

    chatgpt_cmd+=(--save-raw "$raw_json_path")

    chatgpt_cmd+=("$PROMPT_TEXT")

    run_chatgpt_cmd_with_retry "$CHATGPT_RUN_STDERR" "${chatgpt_cmd[@]}"

    require_file "$corrected_file"
    log "Chunk corretto salvato: $corrected_file"
  done

  log "Avvio import_corrected_for_pdf_docx.py..."
  if [ "$VERBOSE_LOGS" -eq 1 ]; then
    run_logged_command "$IMPORT_STDOUT" "$IMPORT_STDERR" 1 \
      "$VENV_PYTHON" "${SCRIPT_DIR}/${IMPORT_SCRIPT}" \
      --input-dir "$LLM_CORRECTED_DIR" \
      --base-name "$VIDEO_BASENAME" \
      --output-dir "$LLM_MERGED_DIR" \
      --expected-slides "$expected_slides"
  else
    "$VENV_PYTHON" "${SCRIPT_DIR}/${IMPORT_SCRIPT}" \
      --input-dir "$LLM_CORRECTED_DIR" \
      --base-name "$VIDEO_BASENAME" \
      --output-dir "$LLM_MERGED_DIR" \
      --expected-slides "$expected_slides" \
      >"$IMPORT_STDOUT" 2>"$IMPORT_STDERR"
  fi

  require_file "$MERGED_SLIDE_TEXTS_JSON"
  log "JSON finale slide texts pronto: $MERGED_SLIDE_TEXTS_JSON"
}

step_generate_pdf() {
  # Genera PDF e DOCX finali partendo da slide e JSON dei testi corretti.
  if [ "$SKIP_PDF" -eq 1 ]; then
    log "Generazione PDF/DOCX skippata"
    return 0
  fi

  if [ "$PDF_NEEDED" -eq 0 ]; then
    log "Generazione PDF/DOCX non necessaria"
    return 0
  fi

  require_dir "$SLIDES_DIR"
  require_file "${SLIDES_DIR}/slides.csv"
  require_file "$MERGED_SLIDE_TEXTS_JSON"

  log "Avvio slides_and_texts_to_pdf.py..."
  if [ "$VERBOSE_LOGS" -eq 1 ]; then
    run_logged_command "$PDF_STDOUT" "$PDF_STDERR" 1 \
      "$VENV_PYTHON" "${SCRIPT_DIR}/${PDF_SCRIPT}" \
      --input-dir "$SLIDES_DIR" \
      --csv "slides.csv" \
      --slide-texts "$MERGED_SLIDE_TEXTS_JSON" \
      --output-base "$VIDEO_BASENAME"
  else
    "$VENV_PYTHON" "${SCRIPT_DIR}/${PDF_SCRIPT}" \
      --input-dir "$SLIDES_DIR" \
      --csv "slides.csv" \
      --slide-texts "$MERGED_SLIDE_TEXTS_JSON" \
      --output-base "$VIDEO_BASENAME" \
      >"$PDF_STDOUT" 2>"$PDF_STDERR"
  fi

  move_final_outputs_to_workdir
}


