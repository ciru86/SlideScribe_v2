        ROI_MODE="$1"
        ;;
      --enhance-slide)
        ENHANCE_SLIDE=1
        ;;
      --enhance-preset)
        shift; [ "$#" -gt 0 ] || die "Valore mancante per --enhance-preset"
        ENHANCE_PRESET="$1"
        ;;
      --chunk-size)
        shift; [ "$#" -gt 0 ] || die "Valore mancante per --chunk-size"
        CHUNK_SIZE="$1"
        ;;
      --skip-first-sec)
        shift; [ "$#" -gt 0 ] || die "Valore mancante per --skip-first-sec"
        SKIP_FIRST_SEC="$1"
        ;;
      --skip-last-sec)
        shift; [ "$#" -gt 0 ] || die "Valore mancante per --skip-last-sec"
        SKIP_LAST_SEC="$1"
        ;;
      --sub-langs)
        shift; [ "$#" -gt 0 ] || die "Valore mancante per --sub-langs"
        SUB_LANGS="$1"
        ;;
      --ytdlp-mode)
        shift; [ "$#" -gt 0 ] || die "Valore mancante per --ytdlp-mode"
        YTDLP_MODE="$1"
        ;;
      --cookies-from-browser)
        shift; [ "$#" -gt 0 ] || die "Valore mancante per --cookies-from-browser"
        COOKIES_FROM_BROWSER="$1"
        ;;
      --model)
        shift; [ "$#" -gt 0 ] || die "Valore mancante per --model"
        MODEL="$1"
        ;;
      --temperature)
        shift; [ "$#" -gt 0 ] || die "Valore mancante per --temperature"
        TEMPERATURE="$1"
        ;;
      --max-output-tokens)
        shift; [ "$#" -gt 0 ] || die "Valore mancante per --max-output-tokens"
        MAX_OUTPUT_TOKENS="$1"
        ;;
      --effort)
        shift; [ "$#" -gt 0 ] || die "Valore mancante per --effort"
        EFFORT="$1"
        ;;
      --verbosity|--script-verbosity)
        shift; [ "$#" -gt 0 ] || die "Valore mancante per --verbosity"
        SCRIPT_VERBOSITY="$1"
        ;;
      --llm-verbosity)
        shift; [ "$#" -gt 0 ] || die "Valore mancante per --llm-verbosity"
        LLM_VERBOSITY="$1"
        ;;
      --prompt-file)
        shift; [ "$#" -gt 0 ] || die "Valore mancante per --prompt-file"
        PROMPT_FILE="$1"
        ;;
      --config)
        CONFIG_FILE="$CONFIG_DEFAULT"
        ;;
      --config-file)
        shift; [ "$#" -gt 0 ] || die "Valore mancante per --config-file"
        CONFIG_FILE_EXPLICIT="$1"
        ;;
      --delete-intermediate-srts)
        DELETE_INTERMEDIATE_SRTS=1
        ;;
      --delete-raw-json)
        DELETE_RAW_JSON=1
        ;;
      --delete-temp)
        DELETE_TEMP=1
        ;;
      --skip-download)
        SKIP_DOWNLOAD=1
        ;;
      --skip-subs)
        SKIP_SUBS=1
        ;;
      --skip-screenshots)
        SKIP_SCREENSHOTS=1
        ;;
      --skip-llm)
        SKIP_LLM=1
        ;;
      --skip-pdf)
        SKIP_PDF=1
        ;;
      --from-step)
        shift; [ "$#" -gt 0 ] || die "Valore mancante per --from-step"
        FROM_STEP="$1"
        ;;
      --force-all)
        FORCE_ALL=1
        ;;
      --dry-run)
        DRY_RUN=1
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      --manual)
        manual
        exit 0
        ;;
      *)
        die "Opzione non riconosciuta: $1"
        ;;
    esac
    shift
  done
}

apply_verbosity_mode() {
  # Traduce la verbosity logica in tre flag operative.
  case "$SCRIPT_VERBOSITY" in
    quiet)
      QUIET_LOGS=1
      VERBOSE_LOGS=0
      DEBUG_LOGS=0
      ;;
    normal)
      QUIET_LOGS=0
      VERBOSE_LOGS=0
      DEBUG_LOGS=0
      ;;
    verbose)
      QUIET_LOGS=0
      VERBOSE_LOGS=1
      DEBUG_LOGS=0
      ;;
    debug)
      QUIET_LOGS=0
      VERBOSE_LOGS=1
      DEBUG_LOGS=1
      ;;
    *)
      die "Valore non valido per --verbosity: $SCRIPT_VERBOSITY (attesi: quiet|normal|verbose|debug)"
      ;;
  esac
}

validate_number() {
  # Verifica che un parametro sia un intero non negativo.
  local label="$1"
  local value="$2"
  [[ "$value" =~ ^[0-9]+$ ]] || die "$label deve essere un intero positivo: $value"
}

validate_float() {
  # Verifica che un parametro abbia forma numerica decimale semplice.
  local label="$1"
  local value="$2"
  [[ "$value" =~ ^[0-9]+([.][0-9]+)?$ ]] || die "$label deve essere un numero valido: $value"
}

normalize_and_validate_args() {
  # Normalizza eventuali alias numerici e valida tutte le opzioni.
  case "$YTDLP_MODE" in
    auto|system|fallback) ;;
    *) die "Valore non valido per --ytdlp-mode: $YTDLP_MODE (attesi: auto|system|fallback)" ;;
  esac

  if [ -n "$ROI_MODE" ]; then
    case "$ROI_MODE" in
      1) ROI_MODE="shared" ;;
      2) ROI_MODE="separate" ;;
      shared|separate) ;;
      *) die "Valore non valido per --roi-mode: $ROI_MODE (attesi: shared|separate)" ;;
    esac
  fi

  if [ -n "$ENHANCE_PRESET" ]; then
    case "$ENHANCE_PRESET" in
      mild|medium|strong) ;;
      *) die "Valore non valido per --enhance-preset: $ENHANCE_PRESET (attesi: mild|medium|strong)" ;;
    esac
  fi

  if [ -n "$ENHANCE_PRESET" ] && [ "$ENHANCE_SLIDE" -ne 1 ]; then
    die "--enhance-preset richiede --enhance-slide"
  fi

  if [ -n "$FROM_STEP" ]; then
    case "$FROM_STEP" in
      screenshots|llm|pdf) ;;
      *) die "Valore non valido per --from-step: $FROM_STEP (attesi: screenshots|llm|pdf)" ;;
    esac
  fi

  case "$LLM_VERBOSITY" in
    low|medium|high) ;;
    *) die "Valore non valido per --llm-verbosity: $LLM_VERBOSITY (attesi: low|medium|high)" ;;
  esac

  validate_number "--chunk-size" "$CHUNK_SIZE"
  validate_float "--skip-first-sec" "$SKIP_FIRST_SEC"
  validate_float "--skip-last-sec" "$SKIP_LAST_SEC"

  if [ -n "$MAX_OUTPUT_TOKENS" ]; then
    validate_number "--max-output-tokens" "$MAX_OUTPUT_TOKENS"
  fi

  validate_float "--temperature" "$TEMPERATURE"

  [ -z "$TERMINOLOGY_FILE" ] || require_file "$TERMINOLOGY_FILE"
  [ -z "$PROMPT_FILE" ] || require_file "$PROMPT_FILE"

  if [ "$YTDLP_MODE" = "system" ]; then
    require_command yt-dlp
  fi
  if [ "$YTDLP_MODE" = "fallback" ]; then
    [ -x "$YTDLP_FALLBACK_PATH" ] || die "yt-dlp fallback non disponibile/eseguibile: $YTDLP_FALLBACK_PATH"
  fi

  # Espansione logica di --from-step in skip impliciti.
  case "$FROM_STEP" in
    screenshots|"")
      ;;
    llm)
      SKIP_DOWNLOAD=1
      SKIP_SUBS=1
      SKIP_SCREENSHOTS=1
      ;;
    pdf)
      SKIP_DOWNLOAD=1
      SKIP_SUBS=1
      SKIP_SCREENSHOTS=1
      SKIP_LLM=1
      ;;
  esac

  # Combinazioni logicamente contraddittorie.
  if [ "$FROM_STEP" = "llm" ] && [ "$SKIP_LLM" -eq 1 ]; then
    die "Combinazione non valida: --from-step llm con --skip-llm"
  fi
  if [ "$FROM_STEP" = "pdf" ] && [ "$SKIP_PDF" -eq 1 ]; then
    die "Combinazione non valida: --from-step pdf con --skip-pdf"
  fi
}

resolve_inputs() {
  # Risolve tutti gli input richiesti per l'esecuzione.
  # Se mancano e siamo in interattivo, li chiede all'utente.
  if [ -z "$WORKDIR" ]; then
    WORKDIR="$(prompt_nonempty 'Inserisci il path della cartella di lavoro: ')"

    # Correzione per path trascinati nel terminale con spazi escapati come `\ `.
    WORKDIR="${WORKDIR//\\ / }"
  fi

  WORKDIR="$(trim "$WORKDIR")"
  if [[ "$WORKDIR" != /* ]]; then
    WORKDIR="$OUTPUT_BASE/$WORKDIR"
  fi

  mkdir -p "$WORKDIR"
  WORKDIR="$(cd "$WORKDIR" && pwd)"

  if [ "$SKIP_DOWNLOAD" -eq 0 ] || [ "$SKIP_SUBS" -eq 0 ]; then
    if [ -z "$YOUTUBE_URL" ]; then
      YOUTUBE_URL="$(prompt_nonempty 'Inserisci URL video YouTube: ')"
    fi
  fi

  if [ -z "$VIDEO_BASENAME" ]; then
      VIDEO_BASENAME="$(basename "$WORKDIR")"
  fi

  if [ "$SKIP_SCREENSHOTS" -eq 0 ] && [ -z "$ROI_MODE" ]; then
    ROI_MODE="$(prompt_choice_roi)"
  fi

  # LESSON_TOPIC e TERMINOLOGY_CONTEXT restano opzionali:
  # se vuoti verranno inferiti automaticamente dal testo deduplicato.
  LESSON_TOPIC="$(trim "$LESSON_TOPIC")"
  TERMINOLOGY_CONTEXT="$(trim "$TERMINOLOGY_CONTEXT")"
}

