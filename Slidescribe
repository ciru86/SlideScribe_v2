run_logged_command() {
  # Esegue un comando e ne redirige stdout/stderr verso file di log.
  # Se richiesto, mostra anche l'output live a schermo tramite tee.
  local stdout_log="$1"
  local stderr_log="$2"
  local show_on_screen="${3:-0}"
  shift 3

  if [ "$show_on_screen" = "1" ] || [ "$show_on_screen" = "always" ] || [ "$VERBOSE_LOGS" -eq 1 ]; then
    "$@" \
      > >(tee "$stdout_log") \
      2> >(tee "$stderr_log" >&2)
  else
    "$@" >"$stdout_log" 2>"$stderr_log"
  fi
}

build_ytdlp_command() {
  # Costruisce l'array base del comando yt-dlp in base alla modalità scelta.
  local mode="$1"

  YTDLP_CMD=()

  case "$mode" in
    system)
      YTDLP_CMD=(yt-dlp --no-playlist)
      ;;
    fallback)
      YTDLP_CMD=("$YTDLP_FALLBACK_PATH" --no-playlist)
      ;;
    auto)
      YTDLP_CMD=(yt-dlp --no-playlist)
      ;;
    *)
      die "build_ytdlp_command: mode non valido: $mode"
      ;;
  esac

  if [ -n "$COOKIES_FROM_BROWSER" ]; then
    YTDLP_CMD+=(--cookies-from-browser "$COOKIES_FROM_BROWSER")
  fi
}

run_ytdlp_with_policy() {
  # Esegue yt-dlp applicando la policy auto/system/fallback.
  # In modalità auto prova prima system, poi fallback se fallisce.
  local stderr_log="$1"
  local action_label="$2"
  shift 2

  local -a primary_cmd=()
  local -a fallback_cmd=()
  local rc=0

  if [ "$YTDLP_MODE" = "auto" ]; then
    build_ytdlp_command system
    primary_cmd=("${YTDLP_CMD[@]}")
    debug "yt-dlp primary (${action_label}): ${primary_cmd[*]} $*"
    : > "$stderr_log"

    set +e
    "${primary_cmd[@]}" "$@" 2> >(tee -a "$stderr_log" >&2)
    rc=$?
    set -e

    if [ $rc -eq 0 ]; then
      return 0
    fi

    log "yt-dlp primario fallito per ${action_label} (exit ${rc}). Provo fallback: $YTDLP_FALLBACK_PATH"
    [ -x "$YTDLP_FALLBACK_PATH" ] || die "yt-dlp primario fallito e fallback non disponibile/eseguibile: $YTDLP_FALLBACK_PATH"

    build_ytdlp_command fallback
    fallback_cmd=("${YTDLP_CMD[@]}")
    debug "yt-dlp fallback (${action_label}): ${fallback_cmd[*]} $*"

    set +e
    "${fallback_cmd[@]}" "$@" 2> >(tee -a "$stderr_log" >&2)
    rc=$?
    set -e

    [ $rc -eq 0 ] || die "yt-dlp fallito anche col fallback per ${action_label} (exit ${rc}). Vedi log: $stderr_log"
    return 0
  fi

  build_ytdlp_command "$YTDLP_MODE"
  primary_cmd=("${YTDLP_CMD[@]}")
  debug "yt-dlp (${action_label}): ${primary_cmd[*]} $*"
  : > "$stderr_log"

  set +e
  "${primary_cmd[@]}" "$@" 2> >(tee -a "$stderr_log" >&2)
  rc=$?
  set -e

  [ $rc -eq 0 ] || die "yt-dlp fallito per ${action_label} (exit ${rc}). Vedi log: $stderr_log"
}

validate_youtube_url() {
  # Validazione preventiva dell'URL via yt-dlp in modalità simulata.
  local url="$1"
  local validation_log
  validation_log="${TMPDIR:-/tmp}/slidescribe_validate_ytdlp.$$.stderr.log"

  run_ytdlp_with_policy "$validation_log" "validazione URL" --simulate --skip-download -- "$url" >/dev/null
  rm -f "$validation_log"
}

run_chatgpt_upload() {
  # Carica un file verso il wrapper chatgpt.
  # Restituisce su stdout il JSON di risposta del wrapper.
  local input_file="$1"
  local stderr_log="${2:-$CHATGPT_UPLOAD_STDERR}"

  if [ "$VERBOSE_LOGS" -eq 1 ]; then
    chatgpt --upload-file "$input_file" 2> >(tee -a "$stderr_log" >&2)
  else
    chatgpt --upload-file "$input_file" 2>>"$stderr_log"
  fi
}

run_chatgpt_cmd_with_retry() {
  local stderr_log="$1"
  shift
  local max_attempts=3
  local attempt=1
  local rc=0

  while [ "$attempt" -le "$max_attempts" ]; do
    log "Tentativo ChatGPT ${attempt}/${max_attempts}..."

    set +e
    if [ "$VERBOSE_LOGS" -eq 1 ]; then
      "$@" 2> >(tee -a "$stderr_log" >&2)
    else
      "$@" 2>>"$stderr_log"
    fi
    rc=$?
    set -e

    if [ "$rc" -eq 0 ]; then
      return 0
    fi

    warn "Chiamata ChatGPT fallita al tentativo ${attempt} (exit ${rc})"
    attempt=$((attempt + 1))
    [ "$attempt" -le "$max_attempts" ] && sleep 3
  done

  return "$rc"
}

