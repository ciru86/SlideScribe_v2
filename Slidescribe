#!/usr/bin/env bash
set -euo pipefail

# ============================================================
# Slidescribe - orchestratore Bash della pipeline:
#   YouTube -> screenshot slide -> pulizia LLM -> PDF/DOCX
#
# Scopo del file:
# - coordinare i vari moduli Python
# - gestire configurazione, CLI, file di config e prompt interattivi
# - decidere quali step eseguire o saltare
# - centralizzare logging, checkpoint e validazioni
#
# Precedenza configurazione:
#   1) flag CLI
#   2) file config
#   3) default interni
#   4) prompt interattivi (solo se permesso)
#
# Note importanti:
# - i prompt interattivi vengono usati solo se manca ancora un valore
#   obbligatorio non fornito da CLI/config/default
# - --prompt-file sostituisce completamente il prompt LLM built-in
# - --from-step definisce da quale fase partire
# - --skip-* rimuove step specifici dal piano di esecuzione
# - --force-all forza il ricalcolo/riesecuzione degli step attivi
#   anche se esistono già file checkpoint compatibili
# ============================================================


# ============================================================
# SCRIPT / TOOL FILES
# ============================================================
# Percorsi relativi dei moduli usati dall'orchestratore.
# Vengono risolti rispetto alla cartella dello script principale.
SCREENSHOT_SCRIPT="modules/Screenshot_grabber.py"
EXPORT_SCRIPT="modules/export_for_llm.py"
DEDUP_SCRIPT="modules/srt_to_text_dedup.py"
IMPORT_SCRIPT="modules/import_corrected_for_pdf_docx.py"
PDF_SCRIPT="modules/slides_and_texts_to_pdf.py"


# ============================================================
# DEFAULTS
# ============================================================
# SCRIPT_NAME: solo nome del file bash corrente.
SCRIPT_NAME="$(basename "$0")"

# SCRIPT_PATH: path reale dello script, con risoluzione dei symlink.
# Compatibile con macOS (evita readlink -f che su macOS non c\'è).
SOURCE_PATH="${BASH_SOURCE[0]}"
while [ -L "$SOURCE_PATH" ]; do
  SOURCE_DIR="$(cd -P "$(dirname "$SOURCE_PATH")" && pwd)"
  LINK_TARGET="$(readlink "$SOURCE_PATH")"
  if [[ "$LINK_TARGET" != /* ]]; then
    SOURCE_PATH="${SOURCE_DIR}/${LINK_TARGET}"
  else
    SOURCE_PATH="$LINK_TARGET"
  fi
done
SCRIPT_PATH="$(cd -P "$(dirname "$SOURCE_PATH")" && pwd)/$(basename "$SOURCE_PATH")"

# SCRIPT_DIR: cartella assoluta reale che contiene questo script.
# Se lo script viene lanciato tramite symlink, punta comunque alla cartella sorgente.
SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
cd "$SCRIPT_DIR"

# Python della virtualenv locale.
VENV_PYTHON="${SCRIPT_DIR}/.venv/bin/python"

# Python della virtualenv locale.
# Tutti i moduli Python della pipeline vengono eseguiti con questo interprete.
VENV_PYTHON="${SCRIPT_DIR}/.venv/bin/python"

# Percorso fallback per yt-dlp quando non si vuole / non si può usare
# quello trovato nel PATH di sistema.
YTDLP_FALLBACK_PATH="$HOME/.local/bin/yt-dlp"

# Array che conterrà il comando yt-dlp effettivamente costruito.
YTDLP_CMD=()

# -----------------------------
# Parametri LLM / pipeline.
# -----------------------------
MODEL="gpt-5.4"
TEMPERATURE="0.3"

# Vuoto di default: se resta vuoto, il wrapper chatgpt non riceve
# il parametro -k e decide lui il comportamento.
MAX_OUTPUT_TOKENS=""
EFFORT=""

# Verbosità separata:
# - SCRIPT_VERBOSITY controlla i log dell'orchestratore Bash
# - LLM_VERBOSITY controlla il wrapper chatgpt
SCRIPT_VERBOSITY="normal"
LLM_VERBOSITY="low"

# Numero di slide per chunk durante l'export verso l'LLM.
CHUNK_SIZE="20"
SKIP_FIRST_SEC="0"
SKIP_LAST_SEC="0"

# Modalità di scelta di yt-dlp:
# - auto     = prova comando di sistema, poi fallback
# - system   = solo yt-dlp nel PATH
# - fallback = solo ~/.local/bin/yt-dlp
YTDLP_MODE="auto"

# Lingue sottotitoli automatici da chiedere a yt-dlp.
SUB_LANGS="it,it-IT,it.*,ita"

# Browser da cui estrarre i cookie, se richiesto.
COOKIES_FROM_BROWSER=""

# Modalità ROI:
# - shared   = slide area e trigger area coincidono / rettangolari
# - separate = trigger separato e slide area poligonale
ROI_MODE=""

# Enhancement opzionale degli screenshot.
ENHANCE_SLIDE=0
ENHANCE_PRESET=""

# Parametri principali di input / contenuto.
WORKDIR=""
OUTPUT_BASE="$SCRIPT_DIR/output"
YOUTUBE_URL=""
VIDEO_BASENAME=""
LESSON_TOPIC=""
TERMINOLOGY_CONTEXT=""
TERMINOLOGY_FILE=""
PROMPT_FILE=""

# Config default e config esplicita da CLI.
CONFIG_DEFAULT="config/slidescribe.conf"
CONFIG_FILE=""
CONFIG_FILE_EXPLICIT=""

# Flag booleane operative.
DRY_RUN=0
FORCE_ALL=0
DELETE_INTERMEDIATE_SRTS=0
DELETE_RAW_JSON=0
DELETE_TEMP=0

SKIP_DOWNLOAD=0
SKIP_SUBS=0
SKIP_SCREENSHOTS=0
SKIP_LLM=0
SKIP_PDF=0

# Punto di ingresso alternativo della pipeline.
FROM_STEP=""   # screenshots | llm | pdf

# -----------------------------
# Variabili derivate dalla verbosity.
# -----------------------------
VERBOSE_LOGS=0
DEBUG_LOGS=0
QUIET_LOGS=0

# -----------------------------
# Variabili runtime valorizzate più avanti.
# -----------------------------
PROMPT_TEXT=""
DOWNLOADED_SRT=""
SCREENSHOTS_NEEDED=1
LLM_PIPELINE_NEEDED=1
PDF_NEEDED=1


# ============================================================
# UTILITY
# ============================================================

die() {
  # Stampa un errore su stderr e termina subito lo script.
  echo "Errore: $*" >&2
  exit 1
}

require_openai_api_key() {
  if [ -f "$HOME/.secrets" ]; then
    # shellcheck source=/dev/null
    source "$HOME/.secrets"
  fi

  [ -n "${OPENAI_API_KEY:-}" ] || die "OPENAI_API_KEY non impostata"
}

warn() {
  # Warning non bloccante su stderr.
  echo "Avviso: $*" >&2
}

log() {
  # Logging standard con timestamp.
  # Se siamo in modalità quiet non stampa nulla.
  if [ "$QUIET_LOGS" -eq 1 ]; then
    return 0
  fi
  printf '[%s] %s\n' "$(date '+%H:%M:%S')" "$*" >&2
}

debug() {
  # Logging diagnostico extra, attivo solo in modalità debug.
  if [ "$DEBUG_LOGS" -eq 1 ]; then
    printf '[%s] DEBUG: %s\n' "$(date '+%H:%M:%S')" "$*" >&2
  fi
}

require_command() {
  # Verifica che un comando esista nel PATH.
  command -v "$1" >/dev/null 2>&1 || die "Comando non trovato: $1"
}

require_file() {
  # Verifica che esista un file regolare.
  [ -f "$1" ] || die "File non trovato: $1"
}

require_dir() {
  # Verifica che esista una directory.
  [ -d "$1" ] || die "Cartella non trovata: $1"
}

trim() {
  # Rimuove spazi iniziali e finali da una stringa.
  # Utile sui valori letti da prompt interattivo.
  local s="$1"
  s="${s#"${s%%[![:space:]]*}"}"
  s="${s%"${s##*[![:space:]]}"}"
  printf '%s' "$s"
}

file_exists_nonempty() {
  # Ritorna vero solo se il file esiste ed è non vuoto.
  [ -f "$1" ] && [ -s "$1" ]
}

timestamp_for_backup() {
  # Timestamp compatto per backup filename-friendly.
  date '+%Y%m%d-%H%M%S'
}

backup_file_if_exists() {
  # Se il file esiste, lo rinomina aggiungendo motivo e timestamp.
  # Serve per non sovrascrivere output finali già presenti.
  local path="$1"
  local reason="${2:-backup}"
  local backup=""

  if [ -f "$path" ]; then
    backup="${path}.${reason}.$(timestamp_for_backup)"
    mv "$path" "$backup"
    log "Backup creato: $backup"
  fi
}

prompt_nonempty() {
  # Chiede un input obbligatorio all'utente.
  local label="$1"
  local value=""


  while true; do
    printf "%s" "$label" > /dev/tty
    IFS= read -r value < /dev/tty
    value="$(trim "$value")"
    [ -n "$value" ] && break
    echo "Valore vuoto. Riprova." > /dev/tty
  done
  printf '%s' "$value"
}

prompt_optional() {
  # Chiede un input opzionale all'utente.
  local message="$1"
  local value


  printf "%s" "$message" > /dev/tty
  IFS= read -r value < /dev/tty
  value="$(trim "$value")"
  printf '%s' "$value"
}

prompt_choice_roi() {
  # Chiede la modalità ROI in forma guidata.
  # Restituisce "shared" oppure "separate".
  local value=""


  while true; do
    cat > /dev/tty <<'EOF'
Scegli la modalità ROI:
  1) shared   - stessa area per trigger e slide (rettangolare)
  2) separate - trigger separato + area slide poligonale
EOF
    printf "Scelta [1/2]: " > /dev/tty
    IFS= read -r value < /dev/tty
    value="$(trim "$value")"

    case "$value" in
      1|shared)
        printf 'shared'
        return 0
        ;;
      2|separate)
        printf 'separate'
        return 0
        ;;
      *)
        echo "Scelta non valida. Riprova." > /dev/tty
        ;;
    esac
  done
}

