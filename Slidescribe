build_llm_prompt() {
  # Costruisce il prompt standard da inviare al wrapper chatgpt.
  # Il prompt cambia leggermente a seconda che l'utente abbia o meno
  # specificato l'argomento della lezione e un contesto terminologico.
  local lesson_topic="$1"
  local terminology_context="$2"
  local intro_line=""
  local terminology_section=""

  if [[ -n "$lesson_topic" ]]; then
    intro_line="Ti fornisco un file TXT strutturato in chunk di slide. È la sbobinatura di una lezione. **${lesson_topic}**. È stata ottenuta da trascrizione automatica (Whisper / speech-to-text), quindi può contenere errori di trascrizione, punteggiatura imperfetta, termini tecnici sbagliati e frasi poco naturali."
  else
    intro_line="Ti fornisco un file TXT strutturato in chunk di slide. È la sbobinatura di una lezione ottenuta da trascrizione automatica (Whisper / speech-to-text), quindi può contenere errori di trascrizione, punteggiatura imperfetta, termini tecnici sbagliati e frasi poco naturali."
  fi

  if [[ -n "$terminology_context" ]]; then
    terminology_section=$(cat <<EOF

Contesto terminologico:
**${terminology_context}**
EOF
)
  fi

  cat <<EOF
${intro_line}

Il tuo compito è ripulire il testo associato a ciascuna slide, migliorandone la leggibilità, ma senza aggiungere contenuti non presenti nell’originale.

Regole obbligatorie:
- NON modificare i delimitatori di chunk
- NON modificare le intestazioni del tipo \
\`----- BEGIN SLIDE 0001 -----\`
- NON modificare le intestazioni del tipo \
\`----- END SLIDE 0001 -----\`
- NON modificare la riga \`TEXT:\`
- NON aggiungere o rimuovere slide
- NON rinumerare le slide
- NON aggiungere commenti, note, introduzioni o conclusioni
- NON aggiungere concetti, spiegazioni, esempi o dettagli che non siano già presenti nel testo
- NON completare arbitrariamente frasi tronche se il contenuto mancante non è chiaramente ricostruibile dal testo stesso
- NON raccordare artificialmente una slide con la successiva o con la precedente
- restituisci solo il file corretto, mantenendo identica la struttura di input

Puoi modificare SOLO il testo sotto \`TEXT:\` per:
- correggere errori di trascrizione
- correggere termini tecnici
- migliorare punteggiatura e leggibilità
- riformulare frasi poco naturali o troppo orali in un italiano più chiaro e scorrevole
- eliminare ripetizioni inutili o piccoli inciampi tipici del parlato, purché il significato resti invariato

${terminology_section}

Importante:
- il chunk può iniziare o finire nel mezzo di un discorso
- alcune frasi possono risultare incomplete perché continuano nella slide successiva o nel chunk successivo
- in questi casi migliora il testo solo se possibile senza inventare il contenuto mancante
- se una correzione non è sicura, mantieni una versione prudente e vicina all’originale

Obiettivo finale:
produrre un testo più leggibile, ma semanticamente fedele all’originale.

Restituisci esclusivamente il testo corretto nello stesso identico formato ricevuto.
EOF
}

build_lesson_metadata_prompt() {
  # Prompt dedicato all'inferenza di argomento lezione e terminologia
  # a partire da un TXT deduplicato derivato dall'SRT originale.
  cat <<'EOF'
Sei un assistente esperto nell’analisi di trascrizioni automatiche (speech-to-text) contenenti errori, distorsioni e termini tecnici mal riconosciuti.

OBIETTIVO:
Ricostruire il contenuto reale della lezione e il dominio tecnico trattato, ignorando errori e rumore del testo.

TASK:
1) Inferisci l’argomento principale della lezione anche se il testo contiene errori o parole distorte.
2) Identifica le 20 parole chiave tecniche più rilevanti per l’argomento.
   - Le parole chiave NON devono necessariamente essere presenti nel testo.
   - Devono rappresentare correttamente il dominio tecnico della lezione.
   - Correggi mentalmente eventuali termini malformati.

REGOLE:
- Argomento lezione: massimo 2-3 frasi.
- Terminologia: esattamente 20 keyword.
- Keyword tecniche, specifiche e coerenti.
- Una sola riga, separate da virgole.
- Nessun testo extra.
- Nessuna introduzione, spiegazione o conclusione.

FORMATO OUTPUT OBBLIGATORIO:
[[Argomento lezione: testo]]
{{Terminologia: keyword1, keyword2, keyword3, ..., keyword20}}
EOF
}

merge_terminology_sources() {
  # Integra nel contesto terminologico eventuale file esterno passato
  # via --terminology-file, anteponendolo al contesto già presente.
  if [ -n "$TERMINOLOGY_FILE" ]; then
    local terminology_file_content
    terminology_file_content="$(cat "$TERMINOLOGY_FILE")"
    if [ -n "$TERMINOLOGY_CONTEXT" ]; then
      TERMINOLOGY_CONTEXT="${terminology_file_content}

${TERMINOLOGY_CONTEXT}"
    else
      TERMINOLOGY_CONTEXT="$terminology_file_content"
    fi
  fi
}

refresh_prompt_text() {
  # Rigenera PROMPT_TEXT dopo che LESSON_TOPIC e/o TERMINOLOGY_CONTEXT
  # sono stati eventualmente inferiti in automatico.
  merge_terminology_sources

  if [ -n "$PROMPT_FILE" ]; then
    PROMPT_TEXT="$(cat "$PROMPT_FILE")"
  else
    PROMPT_TEXT="$(build_llm_prompt "$LESSON_TOPIC" "$TERMINOLOGY_CONTEXT")"
  fi
}

extract_json_field_with_python() {
  # Estrae da una stringa JSON il valore di una certa chiave usando python3.
  # Viene usato, per esempio, per recuperare il file_id dall'upload verso ChatGPT.
  local json_input="$1"
  local field="$2"

  JSON_INPUT="$json_input" python3 - "$field" <<'PY'
import json, os, sys
field = sys.argv[1]
raw = os.environ["JSON_INPUT"]
try:
    data = json.loads(raw)
except Exception:
    sys.exit(2)
value = data.get(field, "")
if isinstance(value, str):
    print(value)
PY
}

extract_lesson_metadata_field() {
  # Estrae dal file di risposta LLM il contenuto dei campi:
  # [[Argomento lezione: ...]]
  # {{Terminologia: ...}}
  local response_file="$1"
  local field="$2"

  "$VENV_PYTHON" - "$response_file" "$field" <<'PY'
import re
import sys
from pathlib import Path

path = Path(sys.argv[1])
field = sys.argv[2]
text = path.read_text(encoding="utf-8", errors="replace")

patterns = {
    "lesson_topic": r"\[\[\s*Argomento lezione:\s*(.*?)\s*\]\]",
    "terminology_context": r"\{\{\s*Terminologia:\s*(.*?)\s*\}\}",
}

pattern = patterns.get(field)
if not pattern:
    sys.exit(2)

m = re.search(pattern, text, re.S)
if not m:
    sys.exit(1)

value = m.group(1).strip()
value = re.sub(r"\s+", " ", value)
print(value)
PY
}

count_slides_from_csv() {
  # Conta il numero di righe dati in slides.csv tramite Python.
  # Viene usato per sapere quante slide finali ci si aspetta dopo il merge.
  local csv_path="$1"

  "$VENV_PYTHON" - "$csv_path" <<'PY'
import csv
import sys
from pathlib import Path
path = Path(sys.argv[1])
with path.open("r", encoding="utf-8-sig", newline="") as f:
    reader = csv.DictReader(f)
    rows = list(reader)
print(len(rows))
PY
}

cleanup_intermediate_srts() {
  # Rimuove gli SRT intermedi solo se richiesto esplicitamente.
  local path

  if [ "$DELETE_INTERMEDIATE_SRTS" -eq 0 ]; then
    log "Cleanup SRT intermedi non richiesto: nessun cleanup SRT"
    return 0
  fi

  for path in "$IT_SRT" "$IT_ORIG_SRT"; do
    if [ -f "$path" ]; then
      rm -f "$path"
      log "Rimosso SRT intermedio: $path"
    fi
  done
}

cleanup_raw_json_files() {
  # Rimuove i raw JSON generati dal wrapper chatgpt solo se richiesto.
  local path

  if [ "$DELETE_RAW_JSON" -eq 0 ]; then
    log "Cleanup raw JSON non richiesto: nessun cleanup raw JSON"
    return 0
  fi

  for path in "$LESSON_CONTEXT_RAW_JSON" "$LLM_CORRECTED_DIR"/*.raw.json; do
    if [ -f "$path" ]; then
      rm -f "$path"
      log "Rimosso raw JSON: $path"
    fi
  done
}

cleanup_temp_files() {
  # Placeholder per eventuali cleanup futuri.
  # Al momento non ci sono temporanei dedicati da rimuovere.
  if [ "$DELETE_TEMP" -eq 0 ]; then
    log "Cleanup temp non richiesto: nessun cleanup temp"
    return 0
  fi

  log "--delete-temp impostato, ma al momento non ci sono file temporanei dedicati da eliminare"
  true
}

move_final_outputs_to_workdir() {
  # I moduli finali generano PDF/DOCX dentro la cartella slides.
  # Questa funzione li sposta nella root della working directory,
  # facendo backup preventivo se i file finali esistono già.
  require_file "$FINAL_PDF_IN_SLIDES"
  require_file "$FINAL_DOCX_IN_SLIDES"

  if [ -f "$FINAL_PDF" ]; then
    backup_file_if_exists "$FINAL_PDF" "pre-move"
  fi
  if [ -f "$FINAL_DOCX" ]; then
    backup_file_if_exists "$FINAL_DOCX" "pre-move"
  fi

  mv -f "$FINAL_PDF_IN_SLIDES" "$FINAL_PDF"
  mv -f "$FINAL_DOCX_IN_SLIDES" "$FINAL_DOCX"

  log "PDF spostato in: $FINAL_PDF"
  log "DOCX spostato in: $FINAL_DOCX"
}

load_config_file() {
  # Carica un file di configurazione shell-compatible.
  # Nota: il file viene eseguito via `source`, quindi deve contenere
  # assegnazioni bash valide.
  local config_path="$1"
  [ -n "$config_path" ] || return 0

  # Se il path non è assoluto, lo risolve rispetto a SCRIPT_DIR.
  if [[ "$config_path" != /* ]]; then
