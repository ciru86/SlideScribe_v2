  [ "$CLI_EFFORT" = "$PRESET_EFFORT" ] || EFFORT="$CLI_EFFORT"
  [ "$CLI_SCRIPT_VERBOSITY" = "$PRESET_SCRIPT_VERBOSITY" ] || SCRIPT_VERBOSITY="$CLI_SCRIPT_VERBOSITY"
  [ "$CLI_LLM_VERBOSITY" = "$PRESET_LLM_VERBOSITY" ] || LLM_VERBOSITY="$CLI_LLM_VERBOSITY"
  [ "$CLI_PROMPT_FILE" = "$PRESET_PROMPT_FILE" ] || PROMPT_FILE="$CLI_PROMPT_FILE"

  # Per le booleane, se da CLI sono state impostate a 1, sovrascrivono il config.
  [ "$CLI_DELETE_INTERMEDIATE_SRTS" -eq 0 ] || DELETE_INTERMEDIATE_SRTS=1
  [ "$CLI_DELETE_RAW_JSON" -eq 0 ] || DELETE_RAW_JSON=1
  [ "$CLI_DELETE_TEMP" -eq 0 ] || DELETE_TEMP=1
  [ "$CLI_SKIP_DOWNLOAD" -eq 0 ] || SKIP_DOWNLOAD=1
  [ "$CLI_SKIP_SUBS" -eq 0 ] || SKIP_SUBS=1
  [ "$CLI_SKIP_SCREENSHOTS" -eq 0 ] || SKIP_SCREENSHOTS=1
  [ "$CLI_SKIP_LLM" -eq 0 ] || SKIP_LLM=1
  [ "$CLI_SKIP_PDF" -eq 0 ] || SKIP_PDF=1
  [ -z "$CLI_FROM_STEP" ] || FROM_STEP="$CLI_FROM_STEP"
  [ "$CLI_FORCE_ALL" -eq 0 ] || FORCE_ALL=1
  [ "$CLI_DRY_RUN" -eq 0 ] || DRY_RUN=1
fi

# 5) applica verbosity e valida configurazione
apply_verbosity_mode
normalize_and_validate_args
check_dependencies
resolve_inputs
setup_paths
refresh_prompt_text

# 6) validazione URL solo se serve davvero yt-dlp
if [ -n "$YOUTUBE_URL" ] && { [ "$SKIP_DOWNLOAD" -eq 0 ] || [ "$SKIP_SUBS" -eq 0 ]; }; then
  validate_youtube_url "$YOUTUBE_URL"
  log "URL verificato"
fi

# 7) calcolo checkpoint e coerenza skip
compute_checkpoints
ensure_prerequisites_for_skips

# 8) dry-run: stampa e termina senza eseguire la pipeline
if [ "$DRY_RUN" -eq 1 ]; then
  print_resolved_config
  print_execution_plan
  exit 0
fi

# 9) logging iniziale riepilogativo
log "Cartella di lavoro: $WORKDIR"
[ -n "$COOKIES_FROM_BROWSER" ] && log "Cookies browser abilitati per yt-dlp: $COOKIES_FROM_BROWSER"
log "Modalità ytdlp: $YTDLP_MODE"
log "Script verbosity: $SCRIPT_VERBOSITY"
log "LLM verbosity: $LLM_VERBOSITY"

# 10) esecuzione degli step della pipeline
step_download_video
step_download_subs
task_screenshots

# Dopo gli screenshot devono esistere almeno cartella slide e CSV.
require_dir "$SLIDES_DIR"
require_file "${SLIDES_DIR}/slides.csv"

run_llm_pipeline

# Se la pipeline LLM non è stata skippata, deve esistere il JSON finale.
if [ "$SKIP_LLM" -eq 0 ]; then
  require_file "$MERGED_SLIDE_TEXTS_JSON"
fi

step_generate_pdf
cleanup_intermediate_srts
cleanup_raw_json_files
cleanup_temp_files

log "Pipeline completata."

echo
echo "Output principali:"
[ -f "$VIDEO_PATH" ] && echo " - Video: $VIDEO_PATH"
[ -f "$ORIGINAL_SRT" ] && echo " - SRT originale: $ORIGINAL_SRT"
[ -d "$SLIDES_DIR" ] && echo " - Cartella slide: $SLIDES_DIR"
[ -d "$LLM_TEXT_DIR" ] && echo " - LLM text: $LLM_TEXT_DIR"
[ -f "$RAW_TEXT_PATH" ] && echo " - Raw text deduplicato: $RAW_TEXT_PATH"
[ -f "$LESSON_CONTEXT_OUTPUT" ] && echo " - Metadata lezione: $LESSON_CONTEXT_OUTPUT"
[ -d "$LLM_CHUNKS_DIR" ] && echo " - Chunk LLM: $LLM_CHUNKS_DIR"
[ -d "$LLM_CORRECTED_DIR" ] && echo " - Chunk corretti: $LLM_CORRECTED_DIR"
[ -f "$MERGED_SLIDE_TEXTS_JSON" ] && echo " - JSON finale slide texts: $MERGED_SLIDE_TEXTS_JSON"
[ -f "$FINAL_PDF" ] && echo " - PDF: $FINAL_PDF"
[ -f "$FINAL_DOCX" ] && echo " - DOCX: $FINAL_DOCX"
echo " - Log: $LOG_DIR"
