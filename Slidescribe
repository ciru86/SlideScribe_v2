  ENHANCE_PRESET
  CHUNK_SIZE="${CHUNK_SIZE:-$CHUNK_SIZE}"
  SKIP_FIRST_SEC="${SKIP_FIRST_SEC:-$SKIP_FIRST_SEC}"
  SKIP_LAST_SEC="${SKIP_LAST_SEC:-$SKIP_LAST_SEC}"
  MODEL="${MODEL:-$MODEL}"
  TEMPERATURE="${TEMPERATURE:-$TEMPERATURE}"
  EFFORT="${EFFORT:-$EFFORT}"
  SCRIPT_VERBOSITY="${SCRIPT_VERBOSITY:-$SCRIPT_VERBOSITY}"
