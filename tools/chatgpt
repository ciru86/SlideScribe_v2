# ============================================================================
# FUNZIONI UTILITY
# ============================================================================
die() {
  echo "Errore: $*" >&2
  exit 1
}

log() {
  [ "$VERBOSE" -eq 1 ] || return 0

  if [ "$SHOW_TIMESTAMPS" -eq 1 ]; then
    printf '[%s] %s\
' "$(date '+%H:%M:%S')" "$*" >&2
  else
    printf '%s\
' "$*" >&2
  fi
}

start_wait_notice() {
  [ "$VERBOSE" -eq 1 ] || return 0
  log "Richiesta inviata all'API. In attesa della risposta del modello..."
}

end_wait_notice() {
  [ "$VERBOSE" -eq 1 ] || return 0
  log "Risposta ricevuta dall'API."
}

require_api_key() {
  [ -n "${OPENAI_API_KEY:-}" ] || die "OPENAI_API_KEY non impostata."
}

# ----------------------------------------------------------------------------
# NUOVA FUNZIONE: require_command
# ----------------------------------------------------------------------------
# Controlla che un comando richiesto esista nel PATH.
#
# La usiamo soprattutto per:
# - curl -> necessario per chiamare l'API
# - jq   -> necessario per costruire/parlare JSON
#
# In questo modo, invece di fallire più avanti con errori poco chiari,
# lo script segnala subito la dipendenza mancante.
# ----------------------------------------------------------------------------
require_command() {
  command -v "$1" >/dev/null 2>&1 || die "comando richiesto non trovato: $1"
}

validate_temperature() {
  jq -en --argjson t "$TEMPERATURE" '$t' >/dev/null 2>&1 \
    || die "temperatura non valida: $TEMPERATURE"
}

validate_tokens() {
  if [ -n "$MAX_OUTPUT_TOKENS" ] && ! [[ "$MAX_OUTPUT_TOKENS" =~ ^[0-9]+$ ]]; then
    die "max output tokens deve essere un intero positivo."
  fi
}

validate_effort() {
  case "$EFFORT" in
    ""|minimal|low|medium|high) ;;
    *) die "effort non valido: $EFFORT (usa: minimal|low|medium|high)" ;;
  esac
}

validate_verbosity() {
  case "$VERBOSITY" in
    ""|low|medium|high) ;;
    *) die "verbosity non valida: $VERBOSITY (usa: low|medium|high)" ;;
  esac
}

# ----------------------------------------------------------------------------
# NUOVA FUNZIONE: is_http_success
# ----------------------------------------------------------------------------
# Ritorna successo solo se lo status HTTP è nella fascia 2xx.
#
# Esempi considerati successo:
# - 200
# - 201
# - 204
#
# Esempi considerati errore:
# - 400
# - 401
# - 404
# - 429
# - 500
# ----------------------------------------------------------------------------
is_http_success() {
  local status="$1"
  [[ "$status" =~ ^2[0-9][0-9]$ ]]
}

show_history() {
  tail -n 40 "$HISTORY_FILE" 2>/dev/null || true
}

show_state() {
  if [ -f "$STATE_FILE" ]; then
    cat "$STATE_FILE"
  fi
}

clear_history_silent() {
  rm -f "$HISTORY_FILE"
}

clear_history() {
  clear_history_silent
  echo "History cancellata."
}

# ----------------------------------------------------------------------------
# NUOVA DISTINZIONE: clear_state_silent vs clear_state
# ----------------------------------------------------------------------------
# Abbiamo separato due funzioni:
#
# 1) clear_state_silent
#    - cancella lo stato senza stampare messaggi
#    - utile internamente, ad esempio per --new
#
# 2) clear_state
#    - cancella lo stato e stampa un messaggio per l'utente
#    - utile nei comandi espliciti tipo --clear-state
# ----------------------------------------------------------------------------
clear_state_silent() {
  rm -f "$STATE_FILE"
}

clear_state() {
  clear_state_silent
  echo "Stato conversazione cancellato."
}

save_history() {
  local prompt="$1"
  printf "%s | model=%s | temp=%s | effort=%s | verbosity=%s | file=%s | prompt=%s\
" \
    "$(date '+%Y-%m-%d %H:%M:%S')" \
    "$MODEL" \
    "$TEMPERATURE" \
    "${EFFORT:-default}" \
    "${VERBOSITY:-default}" \
    "${ATTACHED_FILE_ID:-none}" \
    "$(printf '%s' "$prompt" | tr '\
' ' ')" \
    >> "$HISTORY_FILE"
}

# ----------------------------------------------------------------------------
# ESTRAZIONE TESTO MIGLIORATA
# ----------------------------------------------------------------------------
# Versione più robusta rispetto a quella originale.
#
# Prima cercavamo solo questo percorso:
#   .output[] -> type=="message" -> .content[] -> type=="output_text" -> .text
#
# Adesso proviamo in modo più resiliente:
#
# 1) Se esiste .output_text top-level, usiamo quello
# 2) Altrimenti cerchiamo:
#    - output di tipo "message" con content di tipo "output_text"
#    - output di tipo "output_text" direttamente nell'array
#
# Questo aiuta a gestire più varianti della struttura di risposta.
# ----------------------------------------------------------------------------

extract_text() {
  jq -r '
    if (.output_text? // "") != "" then
      .output_text
    else
      [
        .output[]?
        | if .type == "message" then
            (.content[]? | select(.type == "output_text") | .text?)
          elif .type == "output_text" then
            .text?
          else
            empty
          end
      ]
      | map(select(type == "string" and length > 0))
      | join("\n")
    end
  '
}

extract_response_id() {
  jq -r '.id // empty'
}

# ----------------------------------------------------------------------------
# current_previous_id()
# ----------------------------------------------------------------------------
# Restituisce il previous_response_id da usare nella richiesta corrente.
#
# Logica:
# - se FORCE_NEW=1, NON usiamo alcun previous id
# - se RESUME=1 e STATE_FILE esiste, lo leggiamo
# - altrimenti restituiamo stringa vuota
# ----------------------------------------------------------------------------
current_previous_id() {
  if [ "$FORCE_NEW" -eq 1 ]; then
    return 0
  fi

  if [ "$RESUME" -eq 1 ] && [ -f "$STATE_FILE" ]; then
    cat "$STATE_FILE" 2>/dev/null || true
  fi
}

# ----------------------------------------------------------------------------
# FUNZIONE AGGIUNTA E MIGLIORATA: check_api_error
# ----------------------------------------------------------------------------
# Questa funzione controlla due livelli di errore:
#
# 1) livello HTTP
#    Se lo status non è 2xx, consideriamo la chiamata fallita
#
# 2) livello JSON API
#    Anche con HTTP 200, la risposta potrebbe contenere:
#      { "error": ... }
#
# Inoltre controlliamo che il body sia JSON valido.
#
# Ritorna:
# - 0 se tutto va bene
# - 1 se c'è un errore
# ----------------------------------------------------------------------------
check_api_error() {
  local response="$1"
  local http_status="${2:-}"

  if [ -n "$http_status" ] && ! is_http_success "$http_status"; then
    return 1
  fi

  if ! printf '%s' "$response" | jq -e . >/dev/null 2>&1; then
    return 1
  fi

  if printf '%s' "$response" | jq -e '.error? != null' >/dev/null 2>&1; then
    return 1
  fi

  return 0
}

# ----------------------------------------------------------------------------
# NUOVA FUNZIONE: print_api_error
# ----------------------------------------------------------------------------
# Stampa un errore API in modo più leggibile.
#
# Se la risposta contiene JSON:
# - mostra HTTP status
# - estrae message/type/code se presenti
# - stampa anche il JSON completo formattato
#
# Se la risposta non è JSON:
# - stampa semplicemente il body grezzo
# ----------------------------------------------------------------------------
print_api_error() {
  local response="$1"
  local http_status="${2:-}"

  if [ -n "$http_status" ]; then
    printf 'HTTP status: %s\
' "$http_status" >&2
  fi

  if printf '%s' "$response" | jq -e . >/dev/null 2>&1; then
    local message type code
    message="$(printf '%s' "$response" | jq -r '.error.message // empty')"
    type="$(printf '%s' "$response" | jq -r '.error.type // empty')"
    code="$(printf '%s' "$response" | jq -r '.error.code // empty')"

    [ -n "$message" ] && printf 'Messaggio API: %s\
' "$message" >&2
    [ -n "$type" ] && printf 'Tipo errore API: %s\
' "$type" >&2
    [ -n "$code" ] && printf 'Codice errore API: %s\
' "$code" >&2

    printf '%s' "$response" | jq >&2
  else
    printf '%s\
' "$response" >&2
  fi
}


# ============================================================================
# GESTIONE ALIAS FILE LOCALI
# ============================================================================
save_file_alias() {
  local spec="$1"
  local name="${spec%%=*}"
  local id="${spec#*=}"

  [ -n "$name" ] || die "alias vuoto in --save-file-id"
  [ -n "$id" ] || die "file_id vuoto in --save-file-id"
  [ "$name" != "$spec" ] || die "usa formato NOME=ID per --save-file-id"

  local tmp
  tmp="$(mktemp)"

  jq --arg name "$name" --arg id "$id" '.[$name] = $id' "$FILE_MAP" > "$tmp"
  mv "$tmp" "$FILE_MAP"

  echo "Salvato: $name -> $id"
}

resolve_file_alias() {
  local name="$1"
  jq -r --arg name "$name" '.[$name] // empty' "$FILE_MAP"
}

list_saved_files() {
  jq -r 'to_entries[]? | "\(.key)\	\(.value)"' "$FILE_MAP"
}

remove_file_alias() {
  local name="$1"
  local tmp
  tmp="$(mktemp)"

  jq --arg name "$name" 'del(.[$name])' "$FILE_MAP" > "$tmp"
  mv "$tmp" "$FILE_MAP"

  echo "Alias rimosso: $name"
}


# ============================================================================
# WRAPPER HTTP / API
# ----------------------------------------------------------------------------
# Questa è una delle parti nuove più importanti.
#
# Invece di usare curl "nudo" e basta, ora usiamo funzioni wrapper che:
# - salvano il body in un file temporaneo
# - catturano lo status HTTP separatamente
# - gestiscono meglio gli errori di rete
# - restituiscono il body via stdout
# - salvano lo status in LAST_HTTP_STATUS
#
# Questo evita molti problemi tipici, ad esempio:
# - non distinguere un 200 da un 404
# - mischiare body e status nello stesso output
# - perdere il body di errore
# ============================================================================

# ----------------------------------------------------------------------------
# json_post_request(url, payload)
# ----------------------------------------------------------------------------
# Esegue una richiesta POST con body JSON.
#
# Restituisce:
# - body su stdout
# Salva:
# - status HTTP in LAST_HTTP_STATUS
#
# Se curl fallisce a livello di rete/trasporto, lo script termina con die().
# ----------------------------------------------------------------------------
json_post_request() {
  local url="$1"
  local payload="$2"

  local body_file headers_file response http_status curl_exit
  body_file="$(mktemp)"
  headers_file="$(mktemp)"

  set +e
  curl -sS \
    -D "$headers_file" \
    -o "$body_file" \
    -w '%{http_code}' \
    -H "Authorization: Bearer $OPENAI_API_KEY" \
    -H "Content-Type: application/json" \
    -X POST \
    --data "$payload" \
    "$url" > "${body_file}.status"
  curl_exit=$?
  set -e

  if [ "$curl_exit" -ne 0 ]; then
    rm -f "$body_file" "$headers_file" "${body_file}.status"
    die "errore di rete/curl durante la chiamata POST a $url"
  fi

  response="$(cat "$body_file")"
  http_status="$(tr -d '\r\n' < "${body_file}.status")"

  LAST_HTTP_HEADERS="$(cat "$headers_file")"
  LAST_HTTP_STATUS="$http_status"

  rm -f "$body_file" "$headers_file" "${body_file}.status"

  printf '%s' "$response"
}

# ----------------------------------------------------------------------------
# json_get_request(url)
# ----------------------------------------------------------------------------
# Esegue una richiesta GET verso l'API e gestisce body/status come sopra.
# ----------------------------------------------------------------------------
json_get_request() {
  local url="$1"

  local body_file headers_file response http_status curl_exit
  body_file="$(mktemp)"
  headers_file="$(mktemp)"

  set +e
  curl -sS \
    -D "$headers_file" \
    -o "$body_file" \
    -w '%{http_code}' \
    -H "Authorization: Bearer $OPENAI_API_KEY" \
    "$url" > "${body_file}.status"
  curl_exit=$?
  set -e

  if [ "$curl_exit" -ne 0 ]; then
    rm -f "$body_file" "$headers_file" "${body_file}.status"
    die "errore di rete/curl durante la chiamata a $url"
  fi

  response="$(cat "$body_file")"
  http_status="$(tr -d '\r\n' < "${body_file}.status")"

  LAST_HTTP_HEADERS="$(cat "$headers_file")"
  LAST_HTTP_STATUS="$http_status"

  rm -f "$body_file" "$headers_file" "${body_file}.status"

  printf '%s' "$response"
}

# ----------------------------------------------------------------------------
# multipart_file_upload_request(path)
# ----------------------------------------------------------------------------
# Upload file via multipart/form-data.
#
# Anche qui:
# - body restituito via stdout
# - status salvato in LAST_HTTP_STATUS
# ----------------------------------------------------------------------------
multipart_file_upload_request() {
  local path="$1"

  local body_file headers_file response http_status curl_exit
  body_file="$(mktemp)"
  headers_file="$(mktemp)"

  set +e
  curl -sS \
    -D "$headers_file" \
    -o "$body_file" \
    -w '%{http_code}' \
    -H "Authorization: Bearer $OPENAI_API_KEY" \
    -F purpose="user_data" \
    -F "file=@$path" \
    https://api.openai.com/v1/files > "${body_file}.status"
  curl_exit=$?
  set -e

  if [ $curl_exit -ne 0 ]; then
    rm -f "$body_file" "$headers_file" "${body_file}.status"
    die "errore di rete/curl durante l'upload del file: $path"
  fi

  response="$(cat "$body_file")"
  http_status="$(tr -d '\r\n' < "${body_file}.status")"

  LAST_HTTP_HEADERS="$(cat "$headers_file")"
  LAST_HTTP_STATUS="$http_status"

  rm -f "$body_file" "$headers_file" "${body_file}.status"

  printf '%s' "$response"
}

# ============================================================================
# FILE API
# ============================================================================
upload_file_to_api() {
  local path="$1"
  [ -f "$path" ] || die "file non trovato: $path"

  log "Upload file: $path"
  log "Invio file a OpenAI..."

  local response
  response="$(multipart_file_upload_request "$path")"

  log "Upload completato."
  printf '%s' "$response"
}

check_file_exists_api() {
  local file_id="$1"
  json_get_request "https://api.openai.com/v1/files/$file_id"
}


# ============================================================================
# COSTRUZIONE PAYLOAD E CHIAMATA API
# ============================================================================
build_payload() {
  local prompt="$1"
  local previous_id="${2:-}"

  if [ -n "$ATTACHED_FILE_ID" ]; then
    jq -n \
      --arg model "$MODEL" \
      --arg prompt "$prompt" \
      --arg system "$SYSTEM_PROMPT" \
      --argjson temp "$TEMPERATURE" \
      --arg max_tokens "$MAX_OUTPUT_TOKENS" \
      --arg effort "$EFFORT" \
      --arg verbosity "$VERBOSITY" \
      --arg previous_id "$previous_id" \
      --arg file_id "$ATTACHED_FILE_ID" '
      {
        model: $model,
        input: [
          {
            role: "user",
            content: [
              { type: "input_file", file_id: $file_id },
              { type: "input_text", text: $prompt }
            ]
          }
        ],
        temperature: $temp
      }
      + (if $system != "" then {instructions: $system} else {} end)
      + (if $max_tokens != "" then {max_output_tokens: ($max_tokens | tonumber)} else {} end)
      + (if $previous_id != "" then {previous_response_id: $previous_id} else {} end)
      + (if $effort != "" then {reasoning: {effort: $effort}} else {} end)
      + (if $verbosity != "" then {text: {verbosity: $verbosity}} else {} end)
    '
  else
    jq -n \
      --arg model "$MODEL" \
      --arg input "$prompt" \
      --arg system "$SYSTEM_PROMPT" \
      --argjson temp "$TEMPERATURE" \
      --arg max_tokens "$MAX_OUTPUT_TOKENS" \
      --arg effort "$EFFORT" \
      --arg verbosity "$VERBOSITY" \
      --arg previous_id "$previous_id" '
      {
        model: $model,
        input: $input,
        temperature: $temp
      }
      + (if $system != "" then {instructions: $system} else {} end)
      + (if $max_tokens != "" then {max_output_tokens: ($max_tokens | tonumber)} else {} end)
      + (if $previous_id != "" then {previous_response_id: $previous_id} else {} end)
      + (if $effort != "" then {reasoning: {effort: $effort}} else {} end)
      + (if $verbosity != "" then {text: {verbosity: $verbosity}} else {} end)
    '
  fi
}

call_api() {
  local payload="$1"

  start_wait_notice

  local response
  response="$(json_post_request "https://api.openai.com/v1/responses" "$payload")"

  end_wait_notice
  printf '%s' "$response"
}

print_response() {
  local response="$1"

  if [ "$RAW" -eq 1 ]; then
    if printf '%s' "$response" | jq -e . >/dev/null 2>&1; then
      printf '%s' "$response" | jq
    else
      printf '%s\
' "$response"
    fi
  else
    printf '%s' "$response" | extract_text
  fi
}

save_raw_response() {
  local response="$1"
  local path="$2"
  [ -n "$path" ] || return 0
  printf '%s' "$response" > "$path"
}

save_http_headers() {
  local headers="$1"
  local path="$2"
  [ -n "$path" ] || return 0
  printf '%s' "$headers" > "$path"
}

save_http_status() {
  local status="$1"
  local path="$2"
  [ -n "$path" ] || return 0
  printf '%s\n' "$status" > "$path"
}

# ----------------------------------------------------------------------------
# persist_state(response)
# ----------------------------------------------------------------------------
# Salva sempre l'ultimo response_id ricevuto, anche se RESUME=0.
#
# Questo comportamento è utile perché:
# - il default è non riusare automaticamente il contesto
# - però possiamo comunque conservarlo
# - così l'utente può decidere in seguito di usare --resume
# ----------------------------------------------------------------------------
persist_state() {
  local response="$1"
  local response_id
  response_id="$(printf '%s' "$response" | extract_response_id)"

  if [ -n "$response_id" ]; then
    printf '%s' "$response_id" > "$STATE_FILE"
  fi
}


# ============================================================================
# LETTURA DEL PROMPT
# ============================================================================
read_prompt() {
  local prompt=""

  if [ "$USE_STDIN" -eq 1 ]; then
    prompt="$(cat)"
  elif [ -n "$INPUT_FILE" ]; then
    [ -f "$INPUT_FILE" ] || die "file non trovato: $INPUT_FILE"
    prompt="$(cat "$INPUT_FILE")"
  else
    prompt="$*"
  fi

  [ -n "$prompt" ] || die "prompt mancante."
  printf '%s' "$prompt"
}


# ============================================================================
# GESTIONE MIGLIORATA DI --new
# ----------------------------------------------------------------------------
# apply_new_flag() viene chiamata solo nel flusso "chat request".
#
# Se FORCE_NEW=1:
# - cancella lo stato salvato su disco
# - lascia continuare lo script
# - la richiesta corrente non userà previous_response_id
#
# In questo modo --new fa davvero quello che promette:
# "riparti da zero in questa richiesta"
# ============================================================================
apply_new_flag() {
  if [ "$FORCE_NEW" -eq 1 ]; then
    log "Opzione --new rilevata: azzero lo stato salvato e ignoro il contesto precedente."
    clear_state_silent
  fi
}


# ============================================================================
# MODALITÀ SINGOLA
# ============================================================================
single_mode() {
  local prompt
  log "Lettura input..."
  prompt="$(read_prompt "$@")"

  log "Salvataggio history locale..."
  save_history "$prompt"

  local previous_id=""
  previous_id="$(current_previous_id)"

  if [ -n "$previous_id" ]; then
    log "Uso previous_response_id salvato: $previous_id"
  else
    log "Nessun previous_response_id in uso."
  fi

  local payload response
  log "Costruzione payload per modello: $MODEL"
  payload="$(build_payload "$prompt" "$previous_id")"

  log "Chiamata Responses API..."
  response="$(call_api "$payload")"

  if [ -n "$SAVE_RAW_FILE" ]; then
    log "Salvataggio body JSON grezzo in: $SAVE_RAW_FILE"
    save_raw_response "$response" "$SAVE_RAW_FILE"
  fi

  if [ -n "$SAVE_HEADERS_FILE" ]; then
    log "Salvataggio header HTTP in: $SAVE_HEADERS_FILE"
    save_http_headers "$LAST_HTTP_HEADERS" "$SAVE_HEADERS_FILE"
  fi

  if [ -n "$SAVE_STATUS_FILE" ]; then
    log "Salvataggio status HTTP in: $SAVE_STATUS_FILE"
    save_http_status "$LAST_HTTP_STATUS" "$SAVE_STATUS_FILE"
  fi

  log "HTTP status ricevuto: ${LAST_HTTP_STATUS:-sconosciuto}"
  log "Verifica errori API..."
  if ! check_api_error "$response" "$LAST_HTTP_STATUS"; then
    log "Errore restituito dall'API."
    print_api_error "$response" "$LAST_HTTP_STATUS"
    exit 1
  fi

  if [ -n "$SAVE_RAW_FILE" ]; then
    log "Salvataggio JSON grezzo in: $SAVE_RAW_FILE"
    save_raw_response "$response" "$SAVE_RAW_FILE"
  fi

  log "Persistenza stato conversazione..."
  persist_state "$response"

  if [ -n "$OUTPUT_FILE" ] && [ "$RAW" -eq 0 ]; then
    log "Estrazione testo e salvataggio in: $OUTPUT_FILE"
    print_response "$response" > "$OUTPUT_FILE"
    echo "Salvato in: $OUTPUT_FILE"
  else
    log "Stampa output."
    print_response "$response"
  fi
}


# ============================================================================
# MODALITÀ INTERATTIVA
# ============================================================================
interactive_mode() {
  interactive_help
  echo

  local previous_id=""
  previous_id="$(current_previous_id)"

  if [ -n "$previous_id" ]; then
    log "Modalità interattiva avviata con previous_response_id: $previous_id"
  else
    log "Modalità interattiva avviata senza previous_response_id iniziale."
  fi

  while true; do
    printf "you> "
    IFS= read -r prompt || break

    case "$prompt" in
      /exit)
        break
        ;;
      /new)
        previous_id=""
        clear_state_silent
        echo "Nuova conversazione."
        continue
        ;;
      /history)
        show_history
        continue
        ;;
      /state)
        if [ -n "$previous_id" ]; then
          echo "$previous_id"
        else
          echo "(vuoto)"
        fi
        continue
        ;;
      /help)
        interactive_help
        continue
        ;;
      "")
        continue
        ;;
    esac

    log "Salvataggio history locale..."
    save_history "$prompt"

    local payload response
    log "Costruzione payload per modello: $MODEL"
    payload="$(build_payload "$prompt" "$previous_id")"

    log "Chiamata Responses API..."
    response="$(call_api "$payload")"

  if [ -n "$SAVE_RAW_FILE" ]; then
    log "Salvataggio body JSON grezzo in: $SAVE_RAW_FILE"
    save_raw_response "$response" "$SAVE_RAW_FILE"
  fi

  if [ -n "$SAVE_HEADERS_FILE" ]; then
    log "Salvataggio header HTTP in: $SAVE_HEADERS_FILE"
    save_http_headers "$LAST_HTTP_HEADERS" "$SAVE_HEADERS_FILE"
  fi

  if [ -n "$SAVE_STATUS_FILE" ]; then
    log "Salvataggio status HTTP in: $SAVE_STATUS_FILE"
    save_http_status "$LAST_HTTP_STATUS" "$SAVE_STATUS_FILE"
  fi

    if [ -n "${LAST_HTTP_STATUS:-}" ]; then
  log "HTTP status ricevuto: $LAST_HTTP_STATUS"
else
  log "HTTP status ricevuto: sconosciuto"
fi

    log "Verifica errori API..."
    if ! check_api_error "$response" "$LAST_HTTP_STATUS"; then
      log "Errore restituito dall'API."
      print_api_error "$response" "$LAST_HTTP_STATUS"
      continue
    fi

    if [ -n "$SAVE_RAW_FILE" ]; then
      log "Salvataggio JSON grezzo in: $SAVE_RAW_FILE"
      save_raw_response "$response" "$SAVE_RAW_FILE"
    fi

    log "Output ricevuto e validato."

    if [ "$RAW" -eq 1 ]; then
      log "Stampa output raw."
      print_response "$response"
    else
      log "Estrazione e stampa testo."
      echo
      print_response "$response"
      echo
    fi

    log "Aggiornamento stato conversazione..."
    previous_id="$(printf '%s' "$response" | extract_response_id)"

    if [ -n "$previous_id" ]; then
      printf '%s' "$previous_id" > "$STATE_FILE"
      log "previous_response_id salvato."
    else
      log "Nessun previous_response_id restituito."
    fi
  done
}


# ============================================================================
# PARSING ARGOMENTI
# ============================================================================
if [ $# -eq 0 ]; then
  usage
fi

POSITIONAL=()

while [ $# -gt 0 ]; do
  case "$1" in
    -m)
      [ $# -ge 2 ] || die "manca valore per -m"
      MODEL="$2"
      shift 2
      ;;
    -t)
      [ $# -ge 2 ] || die "manca valore per -t"
      TEMPERATURE="$2"
      shift 2
      ;;
    -s)
      [ $# -ge 2 ] || die "manca valore per -s"
      SYSTEM_PROMPT="$2"
      shift 2
      ;;
    -f)
      [ $# -ge 2 ] || die "manca valore per -f"
      INPUT_FILE="$2"
      shift 2
      ;;
    -o)
      [ $# -ge 2 ] || die "manca valore per -o"
      OUTPUT_FILE="$2"
      shift 2
      ;;
    -k)
      [ $# -ge 2 ] || die "manca valore per -k"
      MAX_OUTPUT_TOKENS="$2"
      shift 2
      ;;
    -r)
      RAW=1
      shift
      ;;
    -i)
      INTERACTIVE=1
      shift
      ;;
    --stdin)
      USE_STDIN=1
      shift
      ;;
    --quiet)
      VERBOSE=0
      shift
      ;;
    --no-timestamps)
      SHOW_TIMESTAMPS=0
      shift
      ;;
    --effort)
      [ $# -ge 2 ] || die "manca valore per --effort"
      EFFORT="$2"
      shift 2
      ;;
    --verbosity)
      [ $# -ge 2 ] || die "manca valore per --verbosity"
      VERBOSITY="$2"
      shift 2
      ;;
    --resume)
      RESUME=1
      shift
      ;;
    --no-resume)
      RESUME=0
      shift
      ;;
    --new)
      FORCE_NEW=1
      shift
      ;;
    --history)
      show_history
      exit 0
      ;;
    --state)
      show_state
      exit 0
      ;;
    --clear-history)
      clear_history
      exit 0
      ;;
    --clear-state)
      clear_state
      exit 0
      ;;
    --upload-file)
      [ $# -ge 2 ] || die "manca valore per --upload-file"
      UPLOAD_FILE="$2"
      shift 2
      ;;
    --file-id)
      [ $# -ge 2 ] || die "manca valore per --file-id"
      ATTACHED_FILE_ID="$2"
      shift 2
      ;;
    --save-file-id)
      [ $# -ge 2 ] || die "manca valore per --save-file-id"
      SAVE_FILE_SPEC="$2"
      shift 2
      ;;
    --use-file)
      [ $# -ge 2 ] || die "manca valore per --use-file"
      USE_FILE_ALIAS="$2"
      shift 2
      ;;
    --list-saved-files)
      SHOW_SAVED_FILES=1
      shift
      ;;
    --remove-saved-file)
      [ $# -ge 2 ] || die "manca valore per --remove-saved-file"
      REMOVE_FILE_ALIAS="$2"
      shift 2
      ;;
    --check-file)
      [ $# -ge 2 ] || die "manca valore per --check-file"
      CHECK_FILE_ID="$2"
      shift 2
      ;;
        --save-raw)
      [ $# -ge 2 ] || die "manca valore per --save-raw"
      SAVE_RAW_FILE="$2"
      shift 2
      ;;
    --save-headers)
      [ $# -ge 2 ] || die "manca valore per --save-headers"
      SAVE_HEADERS_FILE="$2"
      shift 2
      ;;
    --save-status)
      [ $# -ge 2 ] || die "manca valore per --save-status"
      SAVE_STATUS_FILE="$2"
      shift 2
      ;;
    --manual)
      manual
      exit 0
      ;;
    -h|--help)
      usage
      ;;
    --)
      shift
      while [ $# -gt 0 ]; do
        POSITIONAL+=("$1")
        shift
      done
      ;;
    -*)
      die "opzione sconosciuta: $1"
      ;;
    *)
      POSITIONAL+=("$1")
      shift
      ;;
  esac
done

set +u
set -- "${POSITIONAL[@]}"
set -u


# ============================================================================
# CLASSIFICAZIONE DEL TIPO DI OPERAZIONE
# ----------------------------------------------------------------------------
# Questa sezione aiuta a capire "cosa vuole fare" il comando:
#
# 1) Operazioni solo su alias locali
#    es: --save-file-id, --list-saved-files, --remove-saved-file
#
# 2) Operazioni Files API
#    es: --upload-file, --check-file
#
# 3) Richiesta chat vera e propria
#    es: prompt, -i, --stdin, -f, --file-id, --use-file
#
# Questo ci permette di:
# - richiedere solo le dipendenze necessarie
# - evitare di chiedere API key quando non serve
# - gestire meglio i conflitti tra modalità
# ============================================================================
FILE_ALIAS_OP=0
FILE_API_OP=0
CHAT_REQUEST_OP=0

if [ -n "$SAVE_FILE_SPEC" ] || [ "$SHOW_SAVED_FILES" -eq 1 ] || [ -n "$REMOVE_FILE_ALIAS" ]; then
  FILE_ALIAS_OP=1
fi

if [ -n "$UPLOAD_FILE" ] || [ -n "$CHECK_FILE_ID" ]; then
  FILE_API_OP=1
fi

if [ "$INTERACTIVE" -eq 1 ] || [ "$USE_STDIN" -eq 1 ] || [ -n "$INPUT_FILE" ] || [ $# -gt 0 ] || [ -n "$ATTACHED_FILE_ID" ] || [ -n "$USE_FILE_ALIAS" ]; then
  CHAT_REQUEST_OP=1
fi


# ============================================================================
# VALIDAZIONE COERENZA TRA MODALITÀ
# ============================================================================
if [ "$FILE_ALIAS_OP" -eq 1 ] && { [ "$FILE_API_OP" -eq 1 ] || [ "$CHAT_REQUEST_OP" -eq 1 ]; }; then
  die "le operazioni sugli alias (--save-file-id, --list-saved-files, --remove-saved-file) vanno usate da sole"
fi

if [ -n "$UPLOAD_FILE" ] && [ -n "$CHECK_FILE_ID" ]; then
  die "usa solo uno tra --upload-file e --check-file"
fi

if [ "$FILE_API_OP" -eq 1 ] && [ "$CHAT_REQUEST_OP" -eq 1 ]; then
  die "--upload-file e --check-file non sono compatibili con una normale richiesta chat"
fi

if [ "$FORCE_NEW" -eq 1 ] && [ "$CHAT_REQUEST_OP" -eq 0 ]; then
  die "--new ha senso solo insieme a una richiesta chat o con -i"
fi

if [ "$FILE_ALIAS_OP" -eq 0 ] && [ "$FILE_API_OP" -eq 0 ] && [ "$CHAT_REQUEST_OP" -eq 0 ]; then
  die "nessuna azione richiesta. Passa un prompt, usa -i, oppure un comando come --history"
fi


# ============================================================================
# OPERAZIONI SOLO SU ALIAS LOCALI
# ----------------------------------------------------------------------------
# Queste operazioni richiedono jq, ma non curl e non OPENAI_API_KEY.
# ============================================================================
if [ "$FILE_ALIAS_OP" -eq 1 ]; then
  require_command jq

  if [ -n "$SAVE_FILE_SPEC" ]; then
    save_file_alias "$SAVE_FILE_SPEC"
    exit 0
  fi

  if [ "$SHOW_SAVED_FILES" -eq 1 ]; then
    list_saved_files
    exit 0
  fi

  if [ -n "$REMOVE_FILE_ALIAS" ]; then
    remove_file_alias "$REMOVE_FILE_ALIAS"
    exit 0
  fi
fi


# ============================================================================
# OPERAZIONI FILES API
# ----------------------------------------------------------------------------
# Queste operazioni richiedono:
# - jq   -> per formattare la risposta JSON
# - curl -> per chiamare l'API
# - OPENAI_API_KEY
# ============================================================================
if [ "$FILE_API_OP" -eq 1 ]; then
  require_command jq
  require_command curl
  require_api_key

  if [ -n "$UPLOAD_FILE" ]; then
    response="$(upload_file_to_api "$UPLOAD_FILE")"
    if ! check_api_error "$response" "$LAST_HTTP_STATUS"; then
      print_api_error "$response" "$LAST_HTTP_STATUS"
      exit 1
    fi
    printf '%s' "$response" | jq
    exit 0
  fi

  if [ -n "$CHECK_FILE_ID" ]; then
    response="$(check_file_exists_api "$CHECK_FILE_ID")"
    if ! check_api_error "$response" "$LAST_HTTP_STATUS"; then
      print_api_error "$response" "$LAST_HTTP_STATUS"
      exit 1
    fi
    printf '%s' "$response" | jq
    exit 0
  fi
fi


