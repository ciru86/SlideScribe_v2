#!/usr/bin/env bash

# ============================================================================
# MODALITÀ DI ESECUZIONE SICURA
# ----------------------------------------------------------------------------
# set -e        -> termina se un comando fallisce
# set -u        -> errore se usi variabili non definite
# set -o pipefail -> se un comando in una pipeline fallisce, fallisce tutta
#
# Nota:
# questo rende lo script più robusto, ma richiede di gestire esplicitamente
# i casi in cui un comando può fallire "in modo previsto".
# ============================================================================
set -euo pipefail


# ============================================================================
# DEFAULTS / CONFIGURAZIONE INIZIALE
# ----------------------------------------------------------------------------
# Questi sono i valori di default usati se l'utente non passa opzioni.
# ============================================================================
MODEL="gpt-5.4"
TEMPERATURE="1.0"
SYSTEM_PROMPT=""
INPUT_FILE=""
OUTPUT_FILE=""
RAW=0
INTERACTIVE=0
USE_STDIN=0
MAX_OUTPUT_TOKENS=""
EFFORT=""
VERBOSITY=""
SAVE_RAW_FILE=""
SAVE_HEADERS_FILE=""
SAVE_STATUS_FILE=""

# IMPORTANTE:
# RESUME resta volutamente disattivato di default, come richiesto.
# Quindi lo script NON riusa automaticamente previous_response_id,
# a meno che l'utente non passi esplicitamente --resume.
RESUME=0

# ----------------------------------------------------------------------------
# NUOVA VARIABILE: FORCE_NEW
# ----------------------------------------------------------------------------
# Serve per implementare meglio --new.
#
# Prima:
#   --new cancellava lo stato e usciva subito.
#
# Adesso:
#   --new significa "azzera lo stato precedente e continua la richiesta
#   corrente come nuova conversazione".
#
# In pratica:
# - cancella il previous_response_id salvato su file
# - impedisce alla richiesta corrente di usare contesto precedente
# - poi lascia proseguire il normale flusso
# ----------------------------------------------------------------------------
FORCE_NEW=0

POSITIONAL=()

# ----------------------------------------------------------------------------
# Variabili legate alla gestione file OpenAI
# ----------------------------------------------------------------------------
UPLOAD_FILE=""
ATTACHED_FILE_ID=""
USE_FILE_ALIAS=""
SAVE_FILE_SPEC=""
REMOVE_FILE_ALIAS=""
SHOW_SAVED_FILES=0
CHECK_FILE_ID=""

# ----------------------------------------------------------------------------
# Variabili per logging / messaggi di stato
# ----------------------------------------------------------------------------
VERBOSE=1
SHOW_TIMESTAMPS=1

# ----------------------------------------------------------------------------
# NUOVA VARIABILE GLOBALE: LAST_HTTP_STATUS
# ----------------------------------------------------------------------------
# Le funzioni bash restituiscono facilmente una sola "stringa" via stdout.
# Per questo motivo, quando facciamo chiamate HTTP:
# - il body della risposta viene restituito via stdout
# - lo status HTTP (200, 404, 500, ecc.) viene salvato qui
#
# In questo modo possiamo controllare:
# - errori di rete / curl
# - errori HTTP
# - errori applicativi restituiti come JSON con campo .error
# ----------------------------------------------------------------------------
LAST_HTTP_STATUS=""

LAST_HTTP_HEADERS=""


# ============================================================================
# PATHS / STATO LOCALE
# ----------------------------------------------------------------------------
# Lo script salva i propri file locali qui:
#   ~/.local/share/chatgpt
#
# history.log      -> cronologia locale dei prompt
# last_response_id -> ultimo response_id ricevuto
# files.json       -> alias locali -> file_id OpenAI
# ============================================================================
CHATGPT_HOME="${HOME}/.local/share/chatgpt"
HISTORY_FILE="${CHATGPT_HOME}/history.log"
STATE_FILE="${CHATGPT_HOME}/last_response_id"
FILE_MAP="${CHATGPT_HOME}/files.json"

mkdir -p "$CHATGPT_HOME"
[ -f "$FILE_MAP" ] || echo '{}' > "$FILE_MAP"


# ============================================================================
# HELP BREVE
# ============================================================================
usage() {
  cat <<'EOF'
Uso:
  chatgpt [opzioni] "prompt"
  chatgpt -f file.txt [opzioni]
  cat file.txt | chatgpt --stdin [opzioni]
  chatgpt -i [opzioni]

Descrizione:
  CLI per OpenAI Responses API con supporto file_id riutilizzabili.

Opzioni principali:
  -m MODEL              Modello da usare (default: gpt-5.4)
  -t TEMP               Temperatura (default: 1.0)
  -s SYSTEM             Instructions / system prompt
  -f FILE               Legge il prompt da file
  -o FILE               Salva il testo di output su file
  -k TOKENS             Max output tokens
  -r                    Stampa il JSON completo invece del solo testo
  -i                    Modalità interattiva

Opzioni avanzate:
  --stdin               Legge l'input da STDIN / pipe
  --effort LEVEL        minimal | low | medium | high
  --verbosity LEVEL     low | medium | high
  --resume              Riusa previous_response_id salvato localmente
  --no-resume           Non riusa previous_response_id (default)
  --new                 Azzera lo stato salvato e invia la richiesta come nuova conversazione
  --history             Mostra gli ultimi prompt salvati
  --state               Mostra il previous_response_id corrente
  --clear-history       Cancella la history locale
  --clear-state         Cancella il previous_response_id locale
  --quiet               Disattiva i messaggi di stato
  --no-timestamps       Disattiva gli orari nei messaggi di stato
  --save-raw FILE       Salva il body JSON grezzo della risposta API
  --save-headers FILE   Salva gli header HTTP dell’ultima risposta
  --save-status FILE    Salva solo lo status HTTP dell’ultima risposta

File upload / reuse:
  --upload-file PATH        Carica un file su OpenAI e stampa il JSON di risposta
  --file-id ID              Usa un file già caricato nella richiesta corrente
  --save-file-id NOME=ID    Salva un alias locale per un file_id
  --use-file NOME           Usa un alias locale salvato
  --list-saved-files        Elenca gli alias locali salvati
  --remove-saved-file NOME  Elimina un alias locale
  --check-file ID           Verifica lato API se un file_id esiste ancora

Documentazione:
  --manual              Mostra il manuale completo

Help:
  -h, --help            Mostra questo help

Esempi:
  chatgpt "Che giorno è oggi?"
  chatgpt -t 0.2 -k 200 "Spiega il bruxismo in 5 righe"
  chatgpt -s "Rispondi in markdown, stile clinico" "Artralgia ATM"
  chatgpt -f input.txt -o output.md
  cat appunti.txt | chatgpt --stdin -s "Riassumi in punti"
  chatgpt -i -s "Rispondi sempre in italiano"
  chatgpt --resume "Continua la conversazione precedente"
  chatgpt --new "Riparti da zero senza usare il contesto salvato"
  chatgpt --manual
EOF
  exit 0
}


